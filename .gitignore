# ===========================================
# QUIZLET - Git Ignore
# ===========================================

# ===========================================
# NODE DEPENDENCIES
# ===========================================
**/node_modules/
.pnpm-store/
.pnpm-lock.yaml

# ===========================================
# BUILD OUTPUTS
# ===========================================
**/dist/
**/build/
**/.next/
**/out/
**/.turbo/
.next/

# ===========================================
# ENVIRONMENT FILES (CRITICAL)
# ===========================================
# Match .env in ALL directories
.env
.env.local
.env.*.local
.env.*.*

# But keep .env.example files (force add if needed)
# .env.example is ignored by the patterns above

# ===========================================
# SECRETS & KEYS
# ===========================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
credentials.json
service-account.json
*.credentials

# ===========================================
# IDE & EDITOR
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*.swn
~
.*.swp
.vscode/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# ===========================================
# LOGS
# ===========================================
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.log.*

# ===========================================
# TESTING
# ===========================================
coverage/
.nyc_output/
test-results/
playwright-report/

# ===========================================
# CACHE & TEMP
# ===========================================
.cache/
.tmp/
.temp/
*.tmp
*.temp

# ===========================================
# MEDIA (Large files)
# ===========================================
*.mp4
*.mov
*.avi
*.zip
*.tar.gz
*.rar
*.7z

# ===========================================
# PYTHON (if any)
# ===========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env/

# ===========================================
# SWAGGER/OpenAPI (generated)
# ===========================================
**/api/docs

# ===========================================
# MISC
# ===========================================
*.tgz
.eslintcache
.stylelintcache
