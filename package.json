{
  "name": "quizlet-clone",
  "version": "1.0.0",
  "private": true,
  "description": "Quizlet Clone - Full-stack flashcard application",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @quizlet/api dev",
    "dev:web": "pnpm --filter @quizlet/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @quizlet/api build",
    "build:web": "pnpm --filter @quizlet/web build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @quizlet/api test",
    "test:web": "pnpm --filter @quizlet/web test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "format": "pnpm -r format",
    "db:migrate": "pnpm --filter @quizlet/api db:migrate",
    "db:seed": "pnpm --filter @quizlet/api db:seed"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0"
}
