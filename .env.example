# ===========================================
# QUIZLET - Root Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DOMAIN
# ===========================================
DOMAIN=localhost
API_URL=http://localhost:3000
WEB_URL=http://localhost:4000

# ===========================================
# POSTGRESQL
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quizlet

# ===========================================
# REDIS
# ===========================================
REDIS_PASSWORD=

# ===========================================
# JWT SECRETS
# ===========================================
JWT_SECRET=generate-a-secure-32-char-secret-key-here
JWT_REFRESH_SECRET=generate-another-32-char-secret-key

# ===========================================
# AI PROVIDERS
# ===========================================
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================
# AWS (S3)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=quizlet-media

# ===========================================
# GITHUB OAUTH (Optional)
# ===========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# GOOGLE OAUTH (Optional)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# DEVELOPMENT
# ===========================================
NODE_ENV=development
DEBUG=true
