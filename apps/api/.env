# Application
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:4000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=quizlet

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=quizlet-super-secret-jwt-key-at-least-32-characters-for-security
JWT_REFRESH_SECRET=quizlet-super-secret-refresh-key-at-least-32-characters-for-security

# AWS S3 (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=quizlet-media
S3_CDN_URL=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@quizlet-clone.com

# Storage
MAX_FILE_SIZE=10485760
