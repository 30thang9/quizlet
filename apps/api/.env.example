# ===========================================
# QUIZLET API - Environment Configuration
# ===========================================

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/v1
CORS_ORIGINS=http://localhost:4000,http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=quizlet

# ===========================================
# REDIS (Caching & Sessions)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# AI PROVIDERS (Phase 4 - Implemented)
# ===========================================
# Default AI Provider: openai | gemini | claude
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-haiku-20241107

# ===========================================
# FILE STORAGE (AWS S3 - Planned)
# ===========================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# S3_BUCKET=quizlet-media
# S3_CDN_URL=https://cdn.yourdomain.com
# MAX_FILE_SIZE=10485760
# ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,audio/mpeg,audio/wav

# ===========================================
# EMAIL (Implemented)
# ===========================================
# Email Provider: resend | sendgrid | mock (default)
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@quizlet.com

# Resend (Recommended)
# RESEND_API_KEY=re_your_resend_api_key

# SendGrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# App URL for email links
APP_URL=http://localhost:3000
APP_NAME=Quizlet

# ===========================================
# SWAGGER / API DOCS
# ===========================================
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ===========================================
# HEALTH CHECK
# ===========================================
# HEALTH_CHECK_SECRET=your-health-check-secret
