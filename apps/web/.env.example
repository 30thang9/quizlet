# ===========================================
# QUIZLET WEB - Environment Configuration
# ===========================================

# ===========================================
# API & BACKEND
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/v1
API_TIMEOUT=10000

# ===========================================
# AUTHENTICATION
# ===========================================
NEXT_PUBLIC_AUTH_URL=http://localhost:4000
AUTH_TOKEN_KEY=quizlet_token
AUTH_REFRESH_KEY=quizlet_refresh

# ===========================================
# FEATURES (Phase Flags)
# ===========================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_DIAGRAMS=true
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_CLASSES=true

# ===========================================
# AI SETTINGS
# ===========================================
NEXT_PUBLIC_DEFAULT_AI_PROVIDER=openai

# ===========================================
# STORAGE
# ===========================================
NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com
NEXT_PUBLIC_S3_BUCKET=quizlet-media

# ===========================================
# ANALYTICS (Optional)
# ===========================================
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SEGMENT_KEY=

# ===========================================
# SENTRY ERROR TRACKING (Optional)
# ===========================================
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ===========================================
# CLOUDINARY (Media)
# ===========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ===========================================
# INTERCOM (Support Chat)
# ===========================================
NEXT_PUBLIC_INTERCOM_APP_ID=

# ===========================================
# LIMITS
# ===========================================
MAX_CARDS_PER_SET=500
MAX_FILE_SIZE_MB=10
MAX_IMPORT_SIZE_MB=5

# ===========================================
# STUDY SESSION
# ===========================================
SESSION_TIMEOUT_MINUTES=120
AUTO_SAVE_INTERVAL_SECONDS=30

# ===========================================
# PAGINATION
# ===========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
